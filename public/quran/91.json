[{"n":6044,"i":1,"t":"بِسْمِ اللَّهِ الرَّحْمَانِ الرَّحِيمِ وَالشَّمْسِ وَضُحَاهَا"},{"n":6045,"i":2,"t":"وَالْقَمَرِ إِذَا تَلَاهَا"},{"n":6046,"i":3,"t":"وَالنَّهَارِ إِذَا جَلَّاهَا"},{"n":6047,"i":4,"t":"وَاللَّيْلِ إِذَا يَغْشَاهَا"},{"n":6048,"i":5,"t":"وَالسَّمَاءِ وَمَا بَنَاهَا"},{"n":6049,"i":6,"t":"وَالْأَرْضِ وَمَا طَحَاهَا"},{"n":6050,"i":7,"t":"وَنَفْسٍ وَمَا سَوَّاهَا"},{"n":6051,"i":8,"t":"فَأَلْهَمَهَا فُجُورَهَا وَتَقْوَاهَا"},{"n":6052,"i":9,"t":"قَدْ أَفْلَحَ مَنْ زَكَّاهَا"},{"n":6053,"i":10,"t":"وَقَدْ خَابَ مَنْ دَسَّاهَا"},{"n":6054,"i":11,"t":"كَذَّبَتْ ثَمُودُ بِطَغْوَاهَا"},{"n":6055,"i":12,"t":"إِذِ انْبَعَثَ أَشْقَاهَا"},{"n":6056,"i":13,"t":"فَقَالَ لَهُمْ رَسُولُ اللَّهِ نَاقَةَ اللَّهِ وَسُقْيَاهَا"},{"n":6057,"i":14,"t":"فَكَذَّبُوهُ فَعَقَرُوهَا فَدَمْدَمَ عَلَيْهِمْ رَبُّهُمْ بِذَنْبِهِمْ فَسَوَّاهَا"},{"n":6058,"i":15,"t":"وَلَا يَخَافُ عُقْبَاهَا"}]