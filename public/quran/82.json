[{"n":5830,"i":1,"t":"بِسْمِ اللَّهِ الرَّحْمَانِ الرَّحِيمِ إِذَا السَّمَاءُ انْفَطَرَتْ"},{"n":5831,"i":2,"t":"وَإِذَا الْكَوَاكِبُ انْتَثَرَتْ"},{"n":5832,"i":3,"t":"وَإِذَا الْبِحَارُ فُجِّرَتْ"},{"n":5833,"i":4,"t":"وَإِذَا الْقُبُورُ بُعْثِرَتْ"},{"n":5834,"i":5,"t":"عَلِمَتْ نَفْسٌ مَا قَدَّمَتْ وَأَخَّرَتْ"},{"n":5835,"i":6,"t":"يَا أَيُّهَا الْإِنْسَانُ مَا غَرَّكَ بِرَبِّكَ الْكَرِيمِ"},{"n":5836,"i":7,"t":"الَّذِي خَلَقَكَ فَسَوَّاكَ فَعَدَلَكَ"},{"n":5837,"i":8,"t":"فِي أَيِّ صُورَةٍ مَا شَاءَ رَكَّبَكَ"},{"n":5838,"i":9,"t":"كَلَّا بَلْ تُكَذِّبُونَ بِالدِّينِ"},{"n":5839,"i":10,"t":"وَإِنَّ عَلَيْكُمْ لَحَافِظِينَ"},{"n":5840,"i":11,"t":"كِرَامًا كَاتِبِينَ"},{"n":5841,"i":12,"t":"يَعْلَمُونَ مَا تَفْعَلُونَ"},{"n":5842,"i":13,"t":"إِنَّ الْأَبْرَارَ لَفِي نَعِيمٍ"},{"n":5843,"i":14,"t":"وَإِنَّ الْفُجَّارَ لَفِي جَحِيمٍ"},{"n":5844,"i":15,"t":"يَصْلَوْنَهَا يَوْمَ الدِّينِ"},{"n":5845,"i":16,"t":"وَمَا هُمْ عَنْهَا بِغَائِبِينَ"},{"n":5846,"i":17,"t":"وَمَا أَدْرَاكَ مَا يَوْمُ الدِّينِ"},{"n":5847,"i":18,"t":"ثُمَّ مَا أَدْرَاكَ مَا يَوْمُ الدِّينِ"},{"n":5848,"i":19,"t":"يَوْمَ لَا تَمْلِكُ نَفْسٌ لِنَفْسٍ شَيْئًا  وَالْأَمْرُ يَوْمَئِذٍ لِلَّهِ"}]