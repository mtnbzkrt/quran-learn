[{"n":5496,"i":1,"t":"بِسْمِ اللَّهِ الرَّحْمَانِ الرَّحِيمِ يَا أَيُّهَا الْمُدَّثِّرُ"},{"n":5497,"i":2,"t":"قُمْ فَأَنْذِرْ"},{"n":5498,"i":3,"t":"وَرَبَّكَ فَكَبِّرْ"},{"n":5499,"i":4,"t":"وَثِيَابَكَ فَطَهِّرْ"},{"n":5500,"i":5,"t":"وَالرُّجْزَ فَاهْجُرْ"},{"n":5501,"i":6,"t":"وَلَا تَمْنُنْ تَسْتَكْثِرُ"},{"n":5502,"i":7,"t":"وَلِرَبِّكَ فَاصْبِرْ"},{"n":5503,"i":8,"t":"فَإِذَا نُقِرَ فِي النَّاقُورِ"},{"n":5504,"i":9,"t":"فَذَالِكَ يَوْمَئِذٍ يَوْمٌ عَسِيرٌ"},{"n":5505,"i":10,"t":"عَلَى الْكَافِرِينَ غَيْرُ يَسِيرٍ"},{"n":5506,"i":11,"t":"ذَرْنِي وَمَنْ خَلَقْتُ وَحِيدًا"},{"n":5507,"i":12,"t":"وَجَعَلْتُ لَهُ مَالًا مَمْدُودًا"},{"n":5508,"i":13,"t":"وَبَنِينَ شُهُودًا"},{"n":5509,"i":14,"t":"وَمَهَّدْتُ لَهُ تَمْهِيدًا"},{"n":5510,"i":15,"t":"ثُمَّ يَطْمَعُ أَنْ أَزِيدَ"},{"n":5511,"i":16,"t":"كَلَّا  إِنَّهُ كَانَ لِآيَاتِنَا عَنِيدًا"},{"n":5512,"i":17,"t":"سَأُرْهِقُهُ صَعُودًا"},{"n":5513,"i":18,"t":"إِنَّهُ فَكَّرَ وَقَدَّرَ"},{"n":5514,"i":19,"t":"فَقُتِلَ كَيْفَ قَدَّرَ"},{"n":5515,"i":20,"t":"ثُمَّ قُتِلَ كَيْفَ قَدَّرَ"},{"n":5516,"i":21,"t":"ثُمَّ نَظَرَ"},{"n":5517,"i":22,"t":"ثُمَّ عَبَسَ وَبَسَرَ"},{"n":5518,"i":23,"t":"ثُمَّ أَدْبَرَ وَاسْتَكْبَرَ"},{"n":5519,"i":24,"t":"فَقَالَ إِنْ هَاذَا إِلَّا سِحْرٌ يُؤْثَرُ"},{"n":5520,"i":25,"t":"إِنْ هَاذَا إِلَّا قَوْلُ الْبَشَرِ"},{"n":5521,"i":26,"t":"سَأُصْلِيهِ سَقَرَ"},{"n":5522,"i":27,"t":"وَمَا أَدْرَاكَ مَا سَقَرُ"},{"n":5523,"i":28,"t":"لَا تُبْقِي وَلَا تَذَرُ"},{"n":5524,"i":29,"t":"لَوَّاحَةٌ لِلْبَشَرِ"},{"n":5525,"i":30,"t":"عَلَيْهَا تِسْعَةَ عَشَرَ"},{"n":5526,"i":31,"t":"وَمَا جَعَلْنَا أَصْحَابَ النَّارِ إِلَّا مَلَائِكَةً  وَمَا جَعَلْنَا عِدَّتَهُمْ إِلَّا فِتْنَةً لِلَّذِينَ كَفَرُوا لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الْكِتَابَ وَيَزْدَادَ الَّذِينَ آمَنُوا إِيمَانًا  وَلَا يَرْتَابَ الَّذِينَ أُوتُوا الْكِتَابَ وَالْمُؤْمِنُونَ  وَلِيَقُولَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ وَالْكَافِرُونَ مَاذَا أَرَادَ اللَّهُ بِهَاذَا مَثَلًا  كَذَالِكَ يُضِلُّ اللَّهُ مَنْ يَشَاءُ وَيَهْدِي مَنْ يَشَاءُ  وَمَا يَعْلَمُ جُنُودَ رَبِّكَ إِلَّا هُوَ  وَمَا هِيَ إِلَّا ذِكْرَىا لِلْبَشَرِ"},{"n":5527,"i":32,"t":"كَلَّا وَالْقَمَرِ"},{"n":5528,"i":33,"t":"وَاللَّيْلِ إِذْ أَدْبَرَ"},{"n":5529,"i":34,"t":"وَالصُّبْحِ إِذَا أَسْفَرَ"},{"n":5530,"i":35,"t":"إِنَّهَا لَإِحْدَى الْكُبَرِ"},{"n":5531,"i":36,"t":"نَذِيرًا لِلْبَشَرِ"},{"n":5532,"i":37,"t":"لِمَنْ شَاءَ مِنْكُمْ أَنْ يَتَقَدَّمَ أَوْ يَتَأَخَّرَ"},{"n":5533,"i":38,"t":"كُلُّ نَفْسٍ بِمَا كَسَبَتْ رَهِينَةٌ"},{"n":5534,"i":39,"t":"إِلَّا أَصْحَابَ الْيَمِينِ"},{"n":5535,"i":40,"t":"فِي جَنَّاتٍ يَتَسَاءَلُونَ"},{"n":5536,"i":41,"t":"عَنِ الْمُجْرِمِينَ"},{"n":5537,"i":42,"t":"مَا سَلَكَكُمْ فِي سَقَرَ"},{"n":5538,"i":43,"t":"قَالُوا لَمْ نَكُ مِنَ الْمُصَلِّينَ"},{"n":5539,"i":44,"t":"وَلَمْ نَكُ نُطْعِمُ الْمِسْكِينَ"},{"n":5540,"i":45,"t":"وَكُنَّا نَخُوضُ مَعَ الْخَائِضِينَ"},{"n":5541,"i":46,"t":"وَكُنَّا نُكَذِّبُ بِيَوْمِ الدِّينِ"},{"n":5542,"i":47,"t":"حَتَّىا أَتَانَا الْيَقِينُ"},{"n":5543,"i":48,"t":"فَمَا تَنْفَعُهُمْ شَفَاعَةُ الشَّافِعِينَ"},{"n":5544,"i":49,"t":"فَمَا لَهُمْ عَنِ التَّذْكِرَةِ مُعْرِضِينَ"},{"n":5545,"i":50,"t":"كَأَنَّهُمْ حُمُرٌ مُسْتَنْفِرَةٌ"},{"n":5546,"i":51,"t":"فَرَّتْ مِنْ قَسْوَرَةٍ"},{"n":5547,"i":52,"t":"بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنْهُمْ أَنْ يُؤْتَىا صُحُفًا مُنَشَّرَةً"},{"n":5548,"i":53,"t":"كَلَّا  بَلْ لَا يَخَافُونَ الْآخِرَةَ"},{"n":5549,"i":54,"t":"كَلَّا إِنَّهُ تَذْكِرَةٌ"},{"n":5550,"i":55,"t":"فَمَنْ شَاءَ ذَكَرَهُ"},{"n":5551,"i":56,"t":"وَمَا يَذْكُرُونَ إِلَّا أَنْ يَشَاءَ اللَّهُ  هُوَ أَهْلُ التَّقْوَىا وَأَهْلُ الْمَغْفِرَةِ"}]