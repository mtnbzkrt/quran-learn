[{"n":5673,"i":1,"t":"بِسْمِ اللَّهِ الرَّحْمَانِ الرَّحِيمِ عَمَّ يَتَسَاءَلُونَ"},{"n":5674,"i":2,"t":"عَنِ النَّبَإِ الْعَظِيمِ"},{"n":5675,"i":3,"t":"الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ"},{"n":5676,"i":4,"t":"كَلَّا سَيَعْلَمُونَ"},{"n":5677,"i":5,"t":"ثُمَّ كَلَّا سَيَعْلَمُونَ"},{"n":5678,"i":6,"t":"أَلَمْ نَجْعَلِ الْأَرْضَ مِهَادًا"},{"n":5679,"i":7,"t":"وَالْجِبَالَ أَوْتَادًا"},{"n":5680,"i":8,"t":"وَخَلَقْنَاكُمْ أَزْوَاجًا"},{"n":5681,"i":9,"t":"وَجَعَلْنَا نَوْمَكُمْ سُبَاتًا"},{"n":5682,"i":10,"t":"وَجَعَلْنَا اللَّيْلَ لِبَاسًا"},{"n":5683,"i":11,"t":"وَجَعَلْنَا النَّهَارَ مَعَاشًا"},{"n":5684,"i":12,"t":"وَبَنَيْنَا فَوْقَكُمْ سَبْعًا شِدَادًا"},{"n":5685,"i":13,"t":"وَجَعَلْنَا سِرَاجًا وَهَّاجًا"},{"n":5686,"i":14,"t":"وَأَنْزَلْنَا مِنَ الْمُعْصِرَاتِ مَاءً ثَجَّاجًا"},{"n":5687,"i":15,"t":"لِنُخْرِجَ بِهِ حَبًّا وَنَبَاتًا"},{"n":5688,"i":16,"t":"وَجَنَّاتٍ أَلْفَافًا"},{"n":5689,"i":17,"t":"إِنَّ يَوْمَ الْفَصْلِ كَانَ مِيقَاتًا"},{"n":5690,"i":18,"t":"يَوْمَ يُنْفَخُ فِي الصُّورِ فَتَأْتُونَ أَفْوَاجًا"},{"n":5691,"i":19,"t":"وَفُتِحَتِ السَّمَاءُ فَكَانَتْ أَبْوَابًا"},{"n":5692,"i":20,"t":"وَسُيِّرَتِ الْجِبَالُ فَكَانَتْ سَرَابًا"},{"n":5693,"i":21,"t":"إِنَّ جَهَنَّمَ كَانَتْ مِرْصَادًا"},{"n":5694,"i":22,"t":"لِلطَّاغِينَ مَآبًا"},{"n":5695,"i":23,"t":"لَابِثِينَ فِيهَا أَحْقَابًا"},{"n":5696,"i":24,"t":"لَا يَذُوقُونَ فِيهَا بَرْدًا وَلَا شَرَابًا"},{"n":5697,"i":25,"t":"إِلَّا حَمِيمًا وَغَسَّاقًا"},{"n":5698,"i":26,"t":"جَزَاءً وِفَاقًا"},{"n":5699,"i":27,"t":"إِنَّهُمْ كَانُوا لَا يَرْجُونَ حِسَابًا"},{"n":5700,"i":28,"t":"وَكَذَّبُوا بِآيَاتِنَا كِذَّابًا"},{"n":5701,"i":29,"t":"وَكُلَّ شَيْءٍ أَحْصَيْنَاهُ كِتَابًا"},{"n":5702,"i":30,"t":"فَذُوقُوا فَلَنْ نَزِيدَكُمْ إِلَّا عَذَابًا"},{"n":5703,"i":31,"t":"إِنَّ لِلْمُتَّقِينَ مَفَازًا"},{"n":5704,"i":32,"t":"حَدَائِقَ وَأَعْنَابًا"},{"n":5705,"i":33,"t":"وَكَوَاعِبَ أَتْرَابًا"},{"n":5706,"i":34,"t":"وَكَأْسًا دِهَاقًا"},{"n":5707,"i":35,"t":"لَا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا كِذَّ