[{"n":5994,"i":1,"t":"بِسْمِ اللَّهِ الرَّحْمَانِ الرَّحِيمِ وَالْفَجْرِ"},{"n":5995,"i":2,"t":"وَلَيَالٍ عَشْرٍ"},{"n":5996,"i":3,"t":"وَالشَّفْعِ وَالْوَتْرِ"},{"n":5997,"i":4,"t":"وَاللَّيْلِ إِذَا يَسْرِ"},{"n":5998,"i":5,"t":"هَلْ فِي ذَالِكَ قَسَمٌ لِذِي حِجْرٍ"},{"n":5999,"i":6,"t":"أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِعَادٍ"},{"n":6000,"i":7,"t":"إِرَمَ ذَاتِ الْعِمَادِ"},{"n":6001,"i":8,"t":"الَّتِي لَمْ يُخْلَقْ مِثْلُهَا فِي الْبِلَادِ"},{"n":6002,"i":9,"t":"وَثَمُودَ الَّذِينَ جَابُوا الصَّخْرَ بِالْوَادِ"},{"n":6003,"i":10,"t":"وَفِرْعَوْنَ ذِي الْأَوْتَادِ"},{"n":6004,"i":11,"t":"الَّذِينَ طَغَوْا فِي الْبِلَادِ"},{"n":6005,"i":12,"t":"فَأَكْثَرُوا فِيهَا الْفَسَادَ"},{"n":6006,"i":13,"t":"فَصَبَّ عَلَيْهِمْ رَبُّكَ سَوْطَ عَذَابٍ"},{"n":6007,"i":14,"t":"إِنَّ رَبَّكَ لَبِالْمِرْصَادِ"},{"n":6008,"i":15,"t":"فَأَمَّا الْإِنْسَانُ إِذَا مَا ابْتَلَاهُ رَبُّهُ فَأَكْرَمَهُ وَنَعَّمَهُ فَيَقُولُ رَبِّي أَكْرَمَنِ"},{"n":6009,"i":16,"t":"وَأَمَّا إِذَا مَا ابْتَلَاهُ فَقَدَرَ عَلَيْهِ رِزْقَهُ فَيَقُولُ رَبِّي أَهَانَنِ"},{"n":6010,"i":17,"t":"كَلَّا  بَلْ لَا تُكْرِمُونَ الْيَتِيمَ"},{"n":6011,"i":18,"t":"وَلَا تَحَاضُّونَ عَلَىا طَعَامِ الْمِسْكِينِ"},{"n":6012,"i":19,"t":"وَتَأْكُلُونَ التُّرَاثَ أَكْلًا لَمًّا"},{"n":6013,"i":20,"t":"وَتُحِبُّونَ الْمَالَ حُبًّا جَمًّا"},{"n":6014,"i":21,"t":"كَلَّا إِذَا دُكَّتِ الْأَرْضُ دَكًّا دَكًّا"},{"n":6015,"i":22,"t":"وَجَاءَ رَبُّكَ وَالْمَلَكُ صَفًّا صَفًّا"},{"n":6016,"i":23,"t":"وَجِيءَ يَوْمَئِذٍ بِجَهَنَّمَ  يَوْمَئِذٍ يَتَذَكَّرُ الْإِنْسَانُ وَأَنَّىا لَهُ الذِّكْرَىا"},{"n":6017,"i":24,"t":"يَقُولُ يَا لَيْتَنِي قَدَّمْتُ لِحَيَاتِي"},{"n":6018,"i":25,"t":"فَيَوْمَئِذٍ لَا يُعَذِّبُ عَذَابَهُ أَحَدٌ"},{"n":6019,"i":26,"t":"وَلَا يُوثِقُ وَثَاقَهُ أَحَدٌ"},{"n":6020,"i":27,"t":"يَا أَيَّتُهَا النَّفْسُ الْمُطْمَئِنَّةُ"},{"n":6021,"i":28,"t":"ارْجِعِي إِلَىا رَبِّكِ رَاضِيَةً مَرْضِيَّةً"},{"n":6022,"i":29,"t":"فَادْخُلِي فِي عِبَادِي"},{"n":6023,"i":30,"t":"وَادْخُلِي جَنَّتِي"}]