[{"n":6024,"i":1,"t":"بِسْمِ اللَّهِ الرَّحْمَانِ الرَّحِيمِ لَا أُقْسِمُ بِهَاذَا الْبَلَدِ"},{"n":6025,"i":2,"t":"وَأَنْتَ حِلٌّ بِهَاذَا الْبَلَدِ"},{"n":6026,"i":3,"t":"وَوَالِدٍ وَمَا وَلَدَ"},{"n":6027,"i":4,"t":"لَقَدْ خَلَقْنَا الْإِنْسَانَ فِي كَبَدٍ"},{"n":6028,"i":5,"t":"أَيَحْسَبُ أَنْ لَنْ يَقْدِرَ عَلَيْهِ أَحَدٌ"},{"n":6029,"i":6,"t":"يَقُولُ أَهْلَكْتُ مَالًا لُبَدًا"},{"n":6030,"i":7,"t":"أَيَحْسَبُ أَنْ لَمْ يَرَهُ أَحَدٌ"},{"n":6031,"i":8,"t":"أَلَمْ نَجْعَلْ لَهُ عَيْنَيْنِ"},{"n":6032,"i":9,"t":"وَلِسَانًا وَشَفَتَيْنِ"},{"n":6033,"i":10,"t":"وَهَدَيْنَاهُ النَّجْدَيْنِ"},{"n":6034,"i":11,"t":"فَلَا اقْتَحَمَ الْعَقَبَةَ"},{"n":6035,"i":12,"t":"وَمَا أَدْرَاكَ مَا الْعَقَبَةُ"},{"n":6036,"i":13,"t":"فَكُّ رَقَبَةٍ"},{"n":6037,"i":14,"t":"أَوْ إِطْعَامٌ فِي يَوْمٍ ذِي مَسْغَبَةٍ"},{"n":6038,"i":15,"t":"يَتِيمًا ذَا مَقْرَبَةٍ"},{"n":6039,"i":16,"t":"أَوْ مِسْكِينًا ذَا مَتْرَبَةٍ"},{"n":6040,"i":17,"t":"ثُمَّ كَانَ مِنَ الَّذِينَ آمَنُوا وَتَوَاصَوْا بِالصَّبْرِ وَتَوَاصَوْا بِالْمَرْحَمَةِ"},{"n":6041,"i":18,"t":"أُولَائِكَ أَصْحَابُ الْمَيْمَنَةِ"},{"n":6042,"i":19,"t":"وَالَّذِينَ كَفَرُوا بِآيَاتِنَا هُمْ أَصْحَابُ الْمَشْأَمَةِ"},{"n":6043,"i":20,"t":"عَلَيْهِمْ نَارٌ مُؤْصَدَةٌ"}]