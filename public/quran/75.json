[{"n":5552,"i":1,"t":"بِسْمِ اللَّهِ الرَّحْمَانِ الرَّحِيمِ لَا أُقْسِمُ بِيَوْمِ الْقِيَامَةِ"},{"n":5553,"i":2,"t":"وَلَا أُقْسِمُ بِالنَّفْسِ اللَّوَّامَةِ"},{"n":5554,"i":3,"t":"أَيَحْسَبُ الْإِنْسَانُ أَلَّنْ نَجْمَعَ عِظَامَهُ"},{"n":5555,"i":4,"t":"بَلَىا قَادِرِينَ عَلَىا أَنْ نُسَوِّيَ بَنَانَهُ"},{"n":5556,"i":5,"t":"بَلْ يُرِيدُ الْإِنْسَانُ لِيَفْجُرَ أَمَامَهُ"},{"n":5557,"i":6,"t":"يَسْأَلُ أَيَّانَ يَوْمُ الْقِيَامَةِ"},{"n":5558,"i":7,"t":"فَإِذَا بَرِقَ الْبَصَرُ"},{"n":5559,"i":8,"t":"وَخَسَفَ الْقَمَرُ"},{"n":5560,"i":9,"t":"وَجُمِعَ الشَّمْسُ وَالْقَمَرُ"},{"n":5561,"i":10,"t":"يَقُولُ الْإِنْسَانُ يَوْمَئِذٍ أَيْنَ الْمَفَرُّ"},{"n":5562,"i":11,"t":"كَلَّا لَا وَزَرَ"},{"n":5563,"i":12,"t":"إِلَىا رَبِّكَ يَوْمَئِذٍ الْمُسْتَقَرُّ"},{"n":5564,"i":13,"t":"يُنَبَّأُ الْإِنْسَانُ يَوْمَئِذٍ بِمَا قَدَّمَ وَأَخَّرَ"},{"n":5565,"i":14,"t":"بَلِ الْإِنْسَانُ عَلَىا نَفْسِهِ بَصِيرَةٌ"},{"n":5566,"i":15,"t":"وَلَوْ أَلْقَىا مَعَاذِيرَهُ"},{"n":5567,"i":16,"t":"لَا تُحَرِّكْ بِهِ لِسَانَكَ لِتَعْجَلَ بِهِ"},{"n":5568,"i":17,"t":"إِنَّ عَلَيْنَا جَمْعَهُ وَقُرْآنَهُ"},{"n":5569,"i":18,"t":"فَإِذَا قَرَأْنَاهُ فَاتَّبِعْ قُرْآنَهُ"},{"n":5570,"i":19,"t":"ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُ"},{"n":5571,"i":20,"t":"كَلَّا بَلْ تُحِبُّونَ الْعَاجِلَةَ"},{"n":5572,"i":21,"t":"وَتَذَرُونَ الْآخِرَةَ"},{"n":5573,"i":22,"t":"وُجُوهٌ يَوْمَئِذٍ نَاضِرَةٌ"},{"n":5574,"i":23,"t":"إِلَىا رَبِّهَا نَاظِرَةٌ"},{"n":5575,"i":24,"t":"وَوُجُوهٌ يَوْمَئِذٍ بَاسِرَةٌ"},{"n":5576,"i":25,"t":"تَظُنُّ أَنْ يُفْعَلَ بِهَا فَاقِرَةٌ"},{"n":5577,"i":26,"t":"كَلَّا إِذَا بَلَغَتِ التَّرَاقِيَ"},{"n":5578,"i":27,"t":"وَقِيلَ مَنْ  رَاقٍ"},{"n":5579,"i":28,"t":"وَظَنَّ أَنَّهُ الْفِرَاقُ"},{"n":5580,"i":29,"t":"وَالْتَفَّتِ السَّاقُ بِالسَّاقِ"},{"n":5581,"i":30,"t":"إِلَىا رَبِّكَ يَوْمَئِذٍ الْمَسَاقُ"},{"n":5582,"i":31,"t":"فَلَا صَدَّقَ وَلَا صَلَّىا"},{"n":5583,"i":32,"t":"وَلَاكِنْ كَذَّبَ وَتَوَلَّىا"},{"n":5584,"i":33,"t":"ثُمَّ ذَهَبَ إِلَىا أَهْلِهِ يَتَمَطَّىا"},{"n":5585,"