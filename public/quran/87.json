[{"n":5949,"i":1,"t":"بِسْمِ اللَّهِ الرَّحْمَانِ الرَّحِيمِ سَبِّحِ اسْمَ رَبِّكَ الْأَعْلَى"},{"n":5950,"i":2,"t":"الَّذِي خَلَقَ فَسَوَّىا"},{"n":5951,"i":3,"t":"وَالَّذِي قَدَّرَ فَهَدَىا"},{"n":5952,"i":4,"t":"وَالَّذِي أَخْرَجَ الْمَرْعَىا"},{"n":5953,"i":5,"t":"فَجَعَلَهُ غُثَاءً أَحْوَىا"},{"n":5954,"i":6,"t":"سَنُقْرِئُكَ فَلَا تَنْسَىا"},{"n":5955,"i":7,"t":"إِلَّا مَا شَاءَ اللَّهُ  إِنَّهُ يَعْلَمُ الْجَهْرَ وَمَا يَخْفَىا"},{"n":5956,"i":8,"t":"وَنُيَسِّرُكَ لِلْيُسْرَىا"},{"n":5957,"i":9,"t":"فَذَكِّرْ إِنْ نَفَعَتِ الذِّكْرَىا"},{"n":5958,"i":10,"t":"سَيَذَّكَّرُ مَنْ يَخْشَىا"},{"n":5959,"i":11,"t":"وَيَتَجَنَّبُهَا الْأَشْقَى"},{"n":5960,"i":12,"t":"الَّذِي يَصْلَى النَّارَ الْكُبْرَىا"},{"n":5961,"i":13,"t":"ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىا"},{"n":5962,"i":14,"t":"قَدْ أَفْلَحَ مَنْ تَزَكَّىا"},{"n":5963,"i":15,"t":"وَذَكَرَ اسْمَ رَبِّهِ فَصَلَّىا"},{"n":5964,"i":16,"t":"بَلْ تُؤْثِرُونَ الْحَيَاةَ الدُّنْيَا"},{"n":5965,"i":17,"t":"وَالْآخِرَةُ خَيْرٌ وَأَبْقَىا"},{"n":5966,"i":18,"t":"إِنَّ هَاذَا لَفِي الصُّحُفِ الْأُولَىا"},{"n":5967,"i":19,"t":"صُحُفِ إِبْرَاهِيمَ وَمُوسَىا"}]